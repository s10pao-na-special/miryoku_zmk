/ {
  behaviors {
    u_mt: u_mt {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <U_TAPPING_TERM>;
      flavor = "balanced";
      bindings = <&kp>, <&kp>;
    };
    u_lmt: u_lmt {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <250>;
      flavor = "balanced";
      bindings = <&kp>, <&kp>;
      require-prior-idle-ms = <125>;
      hold-trigger-key-positions = <7 8 9 10 11 12  19 20 21 22 23 24  31 32 33 34 35 36  40 41 42>;
      hold-trigger-on-release;
    };
    u_rmt: u_rmt {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <250>;
      flavor = "balanced";
      bindings = <&kp>, <&kp>;
      require-prior-idle-ms = <125>;
      hold-trigger-key-positions = <1 2 3  4  5  6  13 14 15 16 17 18  25 26 27 28 29 30  37 38 39>;
      hold-trigger-on-release;
    };
    u_lt: u_lt {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <U_TAPPING_TERM>;
      flavor = "hold-preferred";
      bindings = <&mo>, <&kp>;
    };
  };
};
